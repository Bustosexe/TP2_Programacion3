@page "/lista-personas"
@using TP2_Programacion_Exequiel.Models

<div class="container mt-4">
    <h2 class="mb-4">Lista de Personas</h2>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Perfil</th>
                    <th>ID</th>
                    <th>Nombre Completo</th>
                    <th>Email</th>
                    <th>Domicilio</th>
                    <th>Fecha de Nacimiento</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var persona in personas)
                {
                    <tr>
                        <td>
                            <img src="@persona.RutaImagen" alt="Avatar de @persona.NombreCompleto" class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;" />
                        </td>
                        <td>@persona.Id</td>
                        <td>@persona.NombreCompleto</td>
                        <td>@persona.Email</td>
                        <td>@persona.Domicilio</td>
                        <td>@persona.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

